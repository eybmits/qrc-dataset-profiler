  "claim_boundary": "This analysis can support property-to-advantage robustness claims. It does not establish coupling, entanglement, or a quantum mechanism.",
  "outputs": [
    "analysis_manifest.json",
    "family_advantage_bootstrap.csv",
    "family_advantage_bootstrap.png",
    "importance_bootstrap.csv",
    "importance_bootstrap.png",
    "importances_all.csv",
    "importances_chaos_nonlinearity_complexity_only.csv",
    "importances_without_predictability_proxies.csv",
    "importances_without_r2_linear.csv",
    "robustness_summary.csv",
